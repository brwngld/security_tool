# PsyberShield scan target fallback
APP_URL=http://127.0.0.1:8000
TARGET_URL=http://127.0.0.1:8000
BASE_URL=http://127.0.0.1:8000

# Local health checks
DEBUG=False
SECRET_KEY=replace-with-a-long-random-value
SERVER_NAME=localhost
DATABASE_URL=postgresql://user:password@localhost:5432/app
SMTP_PASSWORD=replace-with-your-smtp-password

# Browser auth helpers
# Use this with `--password-env PsyberShield_PASSWORD`
PsyberShield_PASSWORD=replace-with-your-browser-password

# Private web dashboard
PSHIELD_DATABASE_URL=postgresql+psycopg://psybershield:change-me@127.0.0.1:5432/psybershield
PSHIELD_SECRET_KEY=replace-with-a-long-random-dashboard-secret
PSHIELD_OUTPUT_DIR=outputs/web
PSHIELD_WEB_HOST=127.0.0.1
PSHIELD_WEB_PORT=8787
PSHIELD_ADMIN_EMAIL=admin@example.com
PSHIELD_ADMIN_PASSWORD=replace-with-a-temporary-admin-password
